NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional. Use https://eu.posthog.com for EU projects.
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# In Supabase Dashboard:
# 1. Enable Google Auth provider.
# 2. Add http://localhost:3000/auth/callback to Auth > URL Configuration > Redirect URLs.
# 3. Run supabase/schema.sql in SQL Editor.
